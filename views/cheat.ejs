<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<link rel="stylesheet" href="/css/cheats.css">
 <div class="box grid">
  <div class="photomain">
    <div class="main-display">
        <div class="comparison-slider active" id="main-frame">
            <div class="img foreground-img" id="fg-img" style="background-image: url('<%= cheat.Photo %>');"></div>
        </div>
    </div>
    <div class="thumb-gallery">
        <img src="<%= cheat.Photo %>" class="thumb active">
        <% cheat.Photos.forEach(ph=>{ %>
        <img src="<%= ph %>" class="thumb" >
        <% }) %>
       </div>
   
  </div>
      <div class="infos">
         <h1><%= cheat.CheatName %></h1>
         <span class="undetected green">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" style="width: 12px; height: 12px;" fill="currentColor">
                  <path d="M256 0c4.6 0 9.2 1 13.4 2.9L457.8 82.8c22 9.3 38.4 31 38.3 57.2-.5 99.2-41.3 280.7-213.6 363.2-16.7 8-36.1 8-52.8 0-172.4-82.5-213.1-264-213.6-363.2-.1-26.2 16.3-47.9 38.3-57.2L242.7 2.9C246.9 1 251.4 0 256 0zm0 66.8l0 378.1c138-66.8 175.1-214.8 176-303.4l-176-74.6 0 0z"/>
         </svg>UNDETECTED</span>
         <div class="quantPrice gap1">
         <div class="quantityCont">
               <h3 class="minibaslik">Quantity</h3>
               <div class="contNumb">
               <span id="minus">-</span>
               <input type="number" id="numb">
               <span id="plus">+</span></div>
         </div>
         <div class="priceCont fontright">
            <h3 class="minibaslik">Total</h3>
            <div id="price"></div>
         </div>
         </div>
         
         <h3 class="minibaslik">Variants</h3>
         
         <div class="variants-container">
            <% cheat.Price.forEach(pr => { %>
                <div class="variant-box" data-price="<%= pr.Price %>">
                    <div class="variant-top">
                        <span class="title"><%= pr.PriceTitle %></span>
                        
                        <% if (pr.Stock > 0) { %>
                            <span class="stock in">IN STOCK (<%= pr.Stock %>)</span>
                        <% } else { %>
                            <span class="stock out">OUT OF STOCK</span>
                        <% } %>
                    </div>
                    <div class="variant-price">$<%= pr.Price %></div>
                </div>
            <% }); %>
         </div>
         <div class="buyCont">
            <button id="addcart"><i class="fa-solid fa-cart-shopping text-sm blue"></i>Add to Cart</button>
            <button id="buy" class="cheat-card" data-cheat-id="<%= cheat._id %>">Buy Now</button>
         </div>
         </div>
      
    </div>
    <div class="bttm">
    <% cheat.infoBlocks.forEach(inf=>{ %>
 <div class="box btmbox">
    <h4 class="mar-bot-1"><%= inf.blockTitle %></h4>
    <p class="mavitxt mar-bot-1" ><%= inf.subTitle %> a</p>
    <% inf.items.forEach(a=>{ %>
        <li class="lis"><span></span><%= a %></li>
        <% }) %>
    </div>
 <% }) %>
</div>
<form action="/cheats/add-price/<%= cheat._id %>" method="POST">
    <input type="text" name="PriceTitle" placeholder="Paket Adı (örn: 1 Günlük)" required>
    <input type="number" name="Price" step="0.01" placeholder="Fiyat" required>
    <input type="number" name="Stock" placeholder="Stok" required>
    <button type="submit">Fiyat Ekle</button>
</form>

<hr>
<form action="/cheats/add-info/<%= cheat._id %>" method="POST">
    <input type="text" name="blockTitle" placeholder="Başlık (örn: Özellikler)" required>
    <input type="text" name="subTitle" placeholder="Başlık (örn: Özellikler)" required>
    <textarea name="items" placeholder="Maddeleri virgülle ayırarak yaz"></textarea>
    <button type="submit">Info Bloğu Ekle</button>
</form>
<script src="/js/cheat.js"></script>