<link rel="stylesheet" href="/css/game.css">
<div class="gameCont">
    <div class="box products">
            <div class="products-grid gap3">
            <% cheats.forEach(ch=>{ %>
            <div class="featured">
               <a href="/cheats/<%=ch._id %>"><img src="<%= ch.Photo %>" alt=""></a>
               <div class="featuredInfo">
                  <div class="namePrice">
                  <h4 class="name"><%= ch.CheatName %> </h4>
                  </div>
                  <span class="undetected green">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" style="width: 12px; height: 12px;" fill="currentColor">
                     <path d="M256 0c4.6 0 9.2 1 13.4 2.9L457.8 82.8c22 9.3 38.4 31 38.3 57.2-.5 99.2-41.3 280.7-213.6 363.2-16.7 8-36.1 8-52.8 0-172.4-82.5-213.1-264-213.6-363.2-.1-26.2 16.3-47.9 38.3-57.2L242.7 2.9C246.9 1 251.4 0 256 0zm0 66.8l0 378.1c138-66.8 175.1-214.8 176-303.4l-176-74.6 0 0z"/>
                  </svg>UNDETECTED</span>
                  <div class="itemBottom">
                     <div class="price half"> <div >STARTING AT</div><span class="gren">$13.99</span> </div>
                     <button class="buyNow"><i class="fa-solid fa-cart-shopping blue"></i>Buy Now</button>
                  </div>            
               </div>
            </div>
            <% }) %>
            
            </div>
         </div>
      
</div>