<div class="checkout-container" id="checkoutData" data-wallets="<%= JSON.stringify(wallets) %>">
    <h2>Ödemeyi Tamamla</h2>
    
    <!-- Sepetteki Ürünleri Listeleme Alanı -->
    <div class="order-items-list" style="margin-bottom: 15px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 15px;">
        <% items.forEach(function(item) { %>
            <div class="order-item" style="margin-bottom: 10px; background: rgba(0,0,0,0.2); padding: 10px; border-radius: 6px;">
                <p style="margin: 0; color: #fff;"><strong>Ürün:</strong> <%= item.cheatName %></p>
                <p style="margin: 5px 0 0 0; font-size: 14px; color: #ccc;">
                    Paket: <%= item.packageTitle %> | Adet: <%= item.qty %>
                </p>
            </div>
        <% }); %>
    </div>

    <p style="font-size: 18px;">Toplam Ödenecek Tutar: <strong>$<%= totalPrice.toFixed(2) %></strong></p>
    
    <div class="paymentblock" style="background: rgba(255, 255, 255, 0.1); padding: 15px; border-radius: 8px; margin-bottom: 15px; text-align: center;">
        <span style="display: block; font-size: 12px; color: #ccc; margin-bottom: 5px;">Ödeme Yapılacak <span id="cryptoName">LTC</span> Adresi:</span>
        <strong id="walletAddressDisplay" style="color: #fff; word-break: break-all; font-family: monospace; font-size: 14px;">Yükleniyor...</strong>
    </div>

    <form class="form" action="/submit-payment" method="POST">
        <!-- YENİ SİSTEM: Tüm sepet verisini backend'e gönderen gizli input -->
        <input type="hidden" name="cartDataRaw" value="<%= cartDataRaw %>">

        <div class="paymentblock">
            <i class="fa-regular fa-envelope" style="color: rgb(255, 255, 255);"></i>
            <input type="email" name="email" placeholder="E-posta adresin (teslimat için)" required>
        </div>
        
        <div class="paymentblock">
            <i class="fa-solid fa-hashtag" style="color: rgb(255, 255, 255);"></i>
            <input type="text" name="txid" placeholder="İşlem Kimliği (TXID)" required>
        </div>
        
        <div class="select-wrapper">
            <select name="method" id="cryptoSelect">
                <option value="ltc">Litecoin (LTC)</option>
                <option value="usdt">USDT (TRC20)</option>
                <option value="btc">Bitcoin (BTC)</option>
                <option value="xmr">Monero (XMR)</option>
            </select>
            <i class="fa-solid fa-chevron-down select-arrow"></i>
        </div>
        
        <button type="submit">Ödemeyi Bitir</button>
    </form>
</div> 

<script src="/js/payment.js"></script>